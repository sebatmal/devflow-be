# 복사해서 쓰기:  cp application.yml.example application.yml
# application.yml 은 .gitignore 처리됨(시크릿 보호) — 절대 커밋 X.
# 시크릿은 여기 직접 채우거나 환경변수로 주입.
server:
  port: 8080

spring:
  datasource:
    url: jdbc:h2:mem:devflow;MODE=MySQL;DB_CLOSE_DELAY=-1;DB_CLOSE_ON_EXIT=FALSE
    username: sa
    password:
    driver-class-name: org.h2.Driver
  jpa:
    hibernate:
      ddl-auto: create-drop
    show-sql: true
    properties:
      hibernate:
        format_sql: true
  h2:
    console:
      enabled: true       # http://localhost:8080/h2-console

api:
  prefix: /api

# GitHub OAuth App (Settings → Developer settings → OAuth Apps)
github:
  client-id: ${GITHUB_CLIENT_ID:}
  client-secret: ${GITHUB_CLIENT_SECRET:}
  redirect-uri: ${GITHUB_REDIRECT_URI:http://localhost:8080/api/auth/github/callback}
  scope: repo read:user read:org
  api-base: https://api.github.com

# 비우면 콜백이 JSON으로 토큰 반환. FE 콜백으로 리다이렉트하려면 그 주소.
app:
  frontend-redirect: ${FRONTEND_REDIRECT:}

jwt:
  secret: ${JWT_SECRET:devflow-local-development-secret-key-change-me-please-0123456789}
  access-expiration-ms: 86400000   # 24h

# 의존성 추천(OpenAI). 키 비면 AI 기능만 비활성, 부팅은 됨.
openai:
  api-key: ${OPENAI_API_KEY:}
  model: gpt-4o-mini

# 이슈 분해(Anthropic) — scripts/issue-decomposer.py 를 호출. Python + `pip install anthropic` 필요.
ai:
  python-path: python3
  script-path: scripts/issue-decomposer.py
  anthropic-api-key: ${ANTHROPIC_API_KEY:}
  anthropic-base-url: ${ANTHROPIC_BASE_URL:}
  timeout-seconds: 60
